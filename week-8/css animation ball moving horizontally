<!DOCTYPE html>
<html>
<head>
<title>Moving and Rotating Circle</title>

<style>

body{
    height:100vh;
    display:flex;
    justify-content:center;
    align-items:center;
    background:#f2f2f2;
}

/* Circle */
.circle{
    width:100px;
    height:100px;
    background:green;
    border-radius:50%;
    animation: moveRotate 4s linear infinite;
}

/* Animation */
@keyframes moveRotate{

    0%{
        transform:translateX(-200px) rotate(0deg);
    }

    50%{
        transform:translateX(200px) rotate(180deg);
    }

    100%{
        transform:translateX(-200px) rotate(360deg);
    }

}

</style>
</head>

<body>

<div class="circle"></div>

</body>
</html>