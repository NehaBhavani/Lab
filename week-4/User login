<!DOCTYPE html>
<html>
<head>
    <title>Two Forms Using Iframes</title>
</head>

<body bgcolor="lightblue">

    <h2 align="center">Two Forms Displayed Using Iframes</h2>

    <table border="2" align="center" width="900" height="450" cellpadding="10">
        <tr>

            <!-- Login Form -->
            <td align="center">
                <iframe width="400" height="350"
                srcdoc='
                <html>
                <body bgcolor="white">
                <form>
                <table border="2" align="center" cellpadding="10" width="300">
                    <tr>
                        <th colspan="2" bgcolor="lightgray">
                            User Login
                        </th>
                    </tr>
                    <tr>
                        <td>Username</td>
                        <td><input type="text"></td>
                    </tr>
                    <tr>
                        <td>Password</td>
                        <td><input type="password"></td>
                    </tr>
                    <tr>
                        <td colspan="2" align="center">
                            <input type="submit" value="Login">
                        </td>
                    </tr>
                </table>
                </form>
                </body>
                </html>'>
                </iframe>
            </td>

            <!-- Registration Form -->
            <td align="center">
                <iframe width="400" height="350"
                srcdoc='
                <html>
                <body bgcolor="white">
                <form>
                <table border="2" align="center" cellpadding="8" width="320">
                    <tr>
                        <th colspan="2" bgcolor="lightgray">
                            User Registration
                        </th>
                    </tr>
                    <tr>
                        <td>Full Name</td>
                        <td><input type="text"></td>
                    </tr>
                    <tr>
                        <td>Email</td>
                        <td><input type="email"></td>
                    </tr>
                    <tr>
                        <td>Phone</td>
                        <td><input type="text"></td>
                    </tr>
                    <tr>
                        <td>Password</td>
                        <td><input type="password"></td>
                    </tr>
                    <tr>
                        <td colspan="2" align="center">
                            <input type="submit" value="Register">
                            <input type="reset" value="Reset">
                        </td>
                    </tr>
                </table>
                </form>
                </body>
                </html>'>
                </iframe>
            </td>

        </tr>
    </table>

</body>
</html>