<!DOCTYPE html>
<html>
<head>
    <title>College Admission Form</title>
</head>

<body bgcolor="lightblue">
<form>
    <table border="2" align="center" cellpadding="10" width="600" bgcolor="white">
    <tr>
        <th colspan="2" bgcolor="lightgray">
        <h2>College Admission Registration</h2>
        </th>
    </tr>
    <tr>
        <td>Full Name</td>
        <td><input type="text" size="30"></td>
    </tr>
    <tr>
        <td>Email</td>
        <td><input type="email" size="30"></td>
     </tr>
     <tr>
        <td>Phone Number</td>
        <td><input type="text" size="30"></td>
    </tr>
    <tr>
        <td>Gender</td>
        <td>
             <input type="radio" name="gender"> Male
            <input type="radio" name="gender"> Female
            <input type="radio" name="gender"> Other
        </td>
    </tr>
    <tr>
        <td>Course Applying For</td>
        <td>
            <select>
                <option>B.Tech</option>
                <option>B.Sc</option>
                <option>B.Com</option>
                <option>BBA</option>
            </select>
        </td>
        </tr>
    <tr>
        <td>Hobbies</td>
        <td>
            <input type="checkbox"> Sports
            <input type="checkbox"> Music
            <input type="checkbox"> Reading
        </td>
    </tr>
    <tr>
        <td>Date of Birth</td>
        <td><input type="date"></td>
    </tr>
    <tr>
        <td>Upload Certificate</td>
        <td><input type="file"></td>
    </tr>
    <tr>
        <td>Address</td>
        <td>
            <textarea rows="4" cols="30"></textarea>
        </td>
    </tr>
    <tr>
        <td colspan="2" align="center">
            <input type="submit" value="Submit">
            <input type="reset" value="Reset">
        </td>
     </tr>
    </table>
</form>
</body>
</html>